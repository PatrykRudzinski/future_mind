# OMDb API key — get one at https://www.omdbapi.com/apikey.aspx
OMDB_API_KEY=your_api_key_here

# Public base URL for OMDb (defaults to https://www.omdbapi.com/)
NEXT_PUBLIC_OMDB_API_URL=https://www.omdbapi.com/

# Public app URL for canonical links and sitemap (defaults to http://localhost:3000)
NEXT_PUBLIC_APP_URL=http://localhost:3000
